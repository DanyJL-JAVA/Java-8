import java.util.*;
import java.util.stream.*;

public class Main {

	public static void main(String[] args) {

		// Fibnocci series

		Integer[] array = Stream.iterate(new Integer[] { 0, 1 }, arr -> new Integer[] { arr[1], arr[0] + arr[1] })
				.map(a -> a[0]).limit(10).toArray(Integer[]::new);

		System.out.println(Arrays.toString(array));

	}

}
