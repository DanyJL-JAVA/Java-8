import java.util.*;
import java.util.stream.*;

public class Main {

	public static boolean IsPrime(Integer num) {

		if (num < 2) {

			return false;

		}

		for (int i = 2; i <= Math.sqrt(num); i++) {

			if (num % i == 0) {

				return false;

			}

		}

		return true;

	}

	public static void main(String[] args) {

		Integer[] PrimeNumbers = IntStream.rangeClosed(2, 101).boxed().filter(Main::IsPrime).toArray(Integer[]::new);

		System.out.println(Arrays.toString(PrimeNumbers));

	}

}
